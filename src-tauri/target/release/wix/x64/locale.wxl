<WixLocalization Culture="en-us" xmlns="http://schemas.microsoft.com/wix/2006/localization"><String Id="TauriLanguage">1033</String><String Id="TauriCodepage">1252</String><String Id="LaunchApp">Launch TaskFlow</String><String Id="DowngradeErrorMessage">A newer version of TaskFlow is already installed.</String><String Id="PathEnvVarFeature">Add the install location of the TaskFlow executable to the PATH system environment variable. This allows the TaskFlow executable to be called from any location.</String><String Id="InstallAppFeature">Installs TaskFlow.</String></WixLocalization>